{
  "name": "linklian-webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4100",
    "build": "next build",
    "start": "next start -p 4100",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "secret:scan": "gitleaks detect --no-git --redact --verbose",
    "secret:scan:full": "gitleaks detect --redact",
    "secret:scan:staged": "gitleaks protect --staged",
    "test": "jest",
    "test:cov": "jest --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "sca": "npm audit --audit-level=high",
    "ci": "npm run sca && npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@mantine/core": "^8.3.14",
    "@mantine/dates": "^8.3.14",
    "@mantine/form": "^8.3.14",
    "@mantine/hooks": "^8.3.14",
    "@tabler/icons-react": "^3.36.0",
    "dayjs": "^1.11.19",
    "jsonwebtoken": "^9.0.3",
    "jwt-decode": "^4.0.0",
    "next": "15.2.3",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.2.3",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "typescript": "^5",
    "typescript-eslint": "^8.54.0"
  }
}
